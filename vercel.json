{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/client/dist/assets/$1"
    },
    {
      "source": "/favicon.svg",
      "destination": "/client/dist/favicon.svg"
    },
    {
      "source": "/icons.svg",
      "destination": "/client/dist/icons.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/client/dist/index.html"
    }
  ]
}
